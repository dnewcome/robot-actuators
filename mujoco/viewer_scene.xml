<mujoco model="cycloidal_viewer">
  <!-- Look-at-the-mechanism scene: just the actuator, no load arm. Driven
       KINEMATICALLY in real time by run.py --view. An input marker spins 10x
       faster than the output marker to show the reduction visually. -->

  <compiler meshdir="../cycloidal/out" angle="degree" autolimits="true"/>
  <option gravity="0 0 0"/>

  <asset>
    <mesh name="ring"    file="ring.stl"    scale="0.001 0.001 0.001"/>
    <mesh name="carrier" file="carrier.stl" scale="0.001 0.001 0.001"/>
    <material name="alu"  rgba="0.70 0.72 0.75 1"/>
    <material name="out"  rgba="0.25 0.55 0.90 1"/>   <!-- output marker (slow) -->
    <material name="in"   rgba="0.90 0.35 0.25 1"/>   <!-- input marker (fast)  -->
  </asset>

  <worldbody>
    <light pos="0.05 -0.05 0.1" dir="-0.4 0.4 -1"/>
    <camera name="iso" pos="0.055 -0.055 0.045"
            xyaxes="0.7 0.7 0 -0.35 0.35 0.87"/>

    <body name="stator">
      <geom type="mesh" mesh="ring" material="alu"/>

      <!-- OUTPUT (carrier) — turns slowly -->
      <body name="output">
        <inertial pos="0 0 0.002" mass="0.01" diaginertia="1e-6 1e-6 1e-6"/>
        <joint name="joint_out" type="hinge" axis="0 0 1"/>
        <geom type="mesh" mesh="carrier" material="out"/>
        <geom type="box" pos="0.0065 0 0.004" size="0.0065 0.0012 0.0012" material="out"/>
      </body>

      <!-- INPUT shaft marker (motor side, just below the ring) — turns 10x faster -->
      <body name="input" pos="0 0 -0.005">
        <inertial pos="0 0 0" mass="0.002" diaginertia="1e-7 1e-7 1e-7"/>
        <joint name="joint_in" type="hinge" axis="0 0 1"/>
        <geom type="cylinder" size="0.0035 0.0025" material="alu"/>
        <geom type="box" pos="0.006 0 0" size="0.006 0.0012 0.0012" material="in"/>
      </body>
    </body>
  </worldbody>
</mujoco>
