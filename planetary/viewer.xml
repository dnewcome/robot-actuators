<mujoco model="planetary_reducer_viewer">
  <!-- Standalone single-stage 4:1 planetary reducer, driven KINEMATICALLY by sim.py.
       Translucent housing + cap show the enclosed can; the internals animate at their
       true ratios: output/carrier 1x | sun 4x (the input) | planets orbit 1x with the
       carrier and spin -3x relative to it. The carrier is now a TWO-PLATE CAGE
       (bottom + top) straddle-mounted on bearings at both ends; both plates ride the
       single output joint. Parts sit on reducer.py's axial datum (z=0 at the motor
       face) so nothing interpenetrates. mm -> m via scale. -->

  <compiler meshdir="out" angle="degree" autolimits="true"/>
  <option gravity="0 0 0"/>

  <asset>
    <mesh name="housing"        file="housing.stl"        scale="0.001 0.001 0.001"/>
    <mesh name="sun"            file="sun.stl"            scale="0.001 0.001 0.001"/>
    <mesh name="planet"         file="planet.stl"         scale="0.001 0.001 0.001"/>
    <mesh name="carrier_bottom" file="carrier_bottom.stl" scale="0.001 0.001 0.001"/>
    <mesh name="carrier_top"    file="carrier_top.stl"    scale="0.001 0.001 0.001"/>
    <mesh name="cap"            file="cap.stl"            scale="0.001 0.001 0.001"/>
    <material name="case" rgba="0.70 0.72 0.75 0.12"/>   <!-- translucent shell      -->
    <material name="sun"  rgba="0.95 0.72 0.10 1"/>      <!-- input: bright, opaque   -->
    <material name="plan" rgba="0.20 0.80 0.40 1"/>
    <material name="carr" rgba="0.80 0.45 0.30 0.45"/>   <!-- translucent: see the sun -->
    <material name="mark" rgba="0.90 0.10 0.10 1"/>      <!-- rotation index markers   -->
  </asset>

  <worldbody>
    <light pos="0.05 -0.05 0.12" dir="-0.4 0.4 -1"/>
    <camera name="iso" pos="0.055 -0.055 0.055" xyaxes="0.7 0.7 0 -0.4 0.4 0.82"/>

    <!-- fixed shell: housing (motor mount + BUILT-IN ring gear + input-bearing pocket)
         + translucent cap (NEMA-17 face + output bearing) -->
    <geom type="mesh" mesh="housing" material="case" contype="0" conaffinity="0"/>
    <geom type="mesh" mesh="cap" material="case" pos="0 0 0.0179" contype="0" conaffinity="0"/>

    <!-- sun on the motor shaft: 4x, the INPUT (gear on top + long press collar hanging
         down through the BIG input bearing's bore). A radial marker reads the fast spin. -->
    <body name="sun_body" pos="0 0 0.0015">
      <joint name="joint_sun" type="hinge" axis="0 0 1"/>
      <geom type="mesh" mesh="sun" material="sun" contype="0" conaffinity="0"/>
      <geom type="box" pos="0.0033 0 0.0105" size="0.0033 0.0009 0.0009" material="mark"
            contype="0" conaffinity="0"/>
    </body>

    <!-- output carrier CAGE: 1x, the slow output. Both plates ride joint_out; the bottom
         plate's boss rides the BIG input bearing low in the flange, the top plate's
         D-shaft rides the output bearing. The 4 planets are captured between the plates. -->
    <body name="carrier_body" pos="0 0 0">
      <joint name="joint_out" type="hinge" axis="0 0 1"/>
      <geom type="mesh" mesh="carrier_bottom" material="carr" pos="0 0 0.007"
            contype="0" conaffinity="0"/>
      <geom type="mesh" mesh="carrier_top" material="carr" pos="0 0 0.0144"
            contype="0" conaffinity="0"/>
      <geom type="box" pos="0.0085 0 0.0178" size="0.0028 0.0011 0.0011" material="mark"
            contype="0" conaffinity="0"/>

      <!-- planets ride the carrier (orbit 1x) and spin -3x about their journals -->
      <body name="planet0" pos="0.0108 0 0.010"><joint name="joint_planet0" type="hinge" axis="0 0 1"/>
        <geom type="mesh" mesh="planet" material="plan" contype="0" conaffinity="0"/></body>
      <body name="planet1" pos="0 0.0108 0.010"><joint name="joint_planet1" type="hinge" axis="0 0 1"/>
        <geom type="mesh" mesh="planet" material="plan" contype="0" conaffinity="0"/></body>
      <body name="planet2" pos="-0.0108 0 0.010"><joint name="joint_planet2" type="hinge" axis="0 0 1"/>
        <geom type="mesh" mesh="planet" material="plan" contype="0" conaffinity="0"/></body>
      <body name="planet3" pos="0 -0.0108 0.010"><joint name="joint_planet3" type="hinge" axis="0 0 1"/>
        <geom type="mesh" mesh="planet" material="plan" contype="0" conaffinity="0"/></body>
    </body>
  </worldbody>
</mujoco>
