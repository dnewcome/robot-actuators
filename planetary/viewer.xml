<mujoco model="planetary_reducer_viewer">
  <!-- Standalone single-stage 4:1 planetary reducer, driven KINEMATICALLY by sim.py.
       Translucent housing + cap show the enclosed can; the internals animate at their
       true ratios: output/carrier 1x | sun 4x (the input) | planets orbit 1x with the
       carrier and spin -3x relative to it. Parts sit on reducer.py's axial datum
       (z=0 at the motor face) so nothing interpenetrates. mm -> m via scale. -->

  <compiler meshdir="out" angle="degree" autolimits="true"/>
  <option gravity="0 0 0"/>

  <asset>
    <mesh name="housing" file="housing.stl" scale="0.001 0.001 0.001"/>
    <mesh name="ring"    file="ring.stl"    scale="0.001 0.001 0.001"/>
    <mesh name="sun"     file="sun.stl"     scale="0.001 0.001 0.001"/>
    <mesh name="planet"  file="planet.stl"  scale="0.001 0.001 0.001"/>
    <mesh name="carrier" file="carrier.stl" scale="0.001 0.001 0.001"/>
    <mesh name="cap"     file="cap.stl"     scale="0.001 0.001 0.001"/>
    <material name="case" rgba="0.70 0.72 0.75 0.12"/>   <!-- translucent shell      -->
    <material name="ring" rgba="0.55 0.57 0.62 1"/>
    <material name="sun"  rgba="0.95 0.72 0.10 1"/>      <!-- input: bright, opaque   -->
    <material name="plan" rgba="0.20 0.80 0.40 1"/>
    <material name="carr" rgba="0.80 0.45 0.30 0.45"/>   <!-- translucent: see the sun -->
    <material name="mark" rgba="0.90 0.10 0.10 1"/>      <!-- rotation index markers   -->
  </asset>

  <worldbody>
    <light pos="0.05 -0.05 0.12" dir="-0.4 0.4 -1"/>
    <camera name="iso" pos="0.055 -0.055 0.050" xyaxes="0.7 0.7 0 -0.4 0.4 0.82"/>

    <!-- fixed shell: housing (motor mount + ring seat) + translucent cap -->
    <geom type="mesh" mesh="housing" material="case" contype="0" conaffinity="0"/>
    <geom type="mesh" mesh="cap" material="case" pos="0 0 0.012" contype="0" conaffinity="0"/>

    <!-- fixed internal ring gear (pressed into the housing) -->
    <geom type="mesh" mesh="ring" material="ring" pos="0 0 0.004" contype="0" conaffinity="0"/>

    <!-- sun on the motor shaft: 4x, the INPUT. Bright + a radial marker so the fast
         spin reads through the translucent carrier stacked above it. -->
    <body name="sun_body" pos="0 0 0.004">
      <joint name="joint_sun" type="hinge" axis="0 0 1"/>
      <geom type="mesh" mesh="sun" material="sun" contype="0" conaffinity="0"/>
      <geom type="box" pos="0.0033 0 0.002" size="0.0033 0.0009 0.0009" material="mark"
            contype="0" conaffinity="0"/>
    </body>

    <!-- output carrier: 1x, the slow output. Carries the 4 planets (orbit) + Ø8 hub. -->
    <body name="carrier_body" pos="0 0 0.0085">
      <joint name="joint_out" type="hinge" axis="0 0 1"/>
      <geom type="mesh" mesh="carrier" material="carr" contype="0" conaffinity="0"/>
      <geom type="box" pos="0.0085 0 0.0105" size="0.0028 0.0011 0.0011" material="mark"
            contype="0" conaffinity="0"/>

      <!-- planets ride the carrier (orbit 1x) and spin -3x about their pins -->
      <body name="planet0" pos="0.009 0 -0.0045"><joint name="joint_planet0" type="hinge" axis="0 0 1"/>
        <geom type="mesh" mesh="planet" material="plan" contype="0" conaffinity="0"/></body>
      <body name="planet1" pos="0 0.009 -0.0045"><joint name="joint_planet1" type="hinge" axis="0 0 1"/>
        <geom type="mesh" mesh="planet" material="plan" contype="0" conaffinity="0"/></body>
      <body name="planet2" pos="-0.009 0 -0.0045"><joint name="joint_planet2" type="hinge" axis="0 0 1"/>
        <geom type="mesh" mesh="planet" material="plan" contype="0" conaffinity="0"/></body>
      <body name="planet3" pos="0 -0.009 -0.0045"><joint name="joint_planet3" type="hinge" axis="0 0 1"/>
        <geom type="mesh" mesh="planet" material="plan" contype="0" conaffinity="0"/></body>
    </body>
  </worldbody>
</mujoco>
